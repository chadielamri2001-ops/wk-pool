function persistPendingChanges(changes){
  try{
    if(changes && changes.length) localStorage.setItem(PENDING_CHANGES_KEY, JSON.stringify(changes));
  }catch(e){}
}
function readPendingChanges(){
  try{
    const raw = localStorage.getItem(PENDING_CHANGES_KEY);
    const parsed = raw ? JSON.parse(raw) : [];
    return Array.isArray(parsed) ? parsed : [];
  }catch(e){
    return [];
  }
}
function clearPendingChanges(){
  try{ localStorage.removeItem(PENDING_CHANGES_KEY); }catch(e){}
}
function scheduleSaveRetry(delay=5000){
  clearSaveRetry();
  updateSyncStatus("error","Opnieuw proberen…");
  saveRetryTimer = setTimeout(()=>{
    saveRetryTimer = null;
    if(saveRequested && !saveRunning) flushSave(false);
  }, delay);
}
async function fetchRemoteShared(){
  const r = await fetch(CONFIG.API_URL + (CONFIG.API_URL.includes("?") ? "&" : "?") + "_=" + Date.now(), {cache:"no-store"});
  if(!r.ok) throw new Error("HTTP "+r.status);
  const data = await r.json();
  return sharedSnapshot(data);
}
async function loadState(){
  if(!CONFIG.API_URL || CONFIG.API_URL.indexOf("http")!==0) return;
  try{
    updateSyncStatus("saving","Laden…");
    const remote = await fetchRemoteShared();
    Object.assign(state, remote);
    lastSyncedShared = sharedSnapshot(remote);
    lastSyncError = null;
    updateSyncStatus("","Gesynchroniseerd");
  }catch(err){
    lastSyncError = "Laden mislukt: " + err.message;
    updateSyncStatus("error","Offline");
  }
}
function saveState(immediate){
  saveRequested = true;
  updateSyncStatus("saving","Opslaan…");
  clearTimeout(saveTimer);
  clearSaveRetry();
  if(immediate) flushSave(true);
  else saveTimer = setTimeout(()=>flushSave(false), 280);
}
async function flushSave(keepalive){
  if(saveRunning){ saveRequested = true; return; }
  if(!CONFIG.API_URL || CONFIG.API_URL.indexOf("http")!==0){ showToast(); return; }
  clearSaveRetry();
  saveRunning = true;
  saveRequested = false;
  let failed = false;
  let changes = [];
  try{
    const local = sharedSnapshot();
    const base = lastSyncedShared || sharedSnapshot({});
    changes = collectChanges(base, local);
    if(!changes.length){
      clearPendingChanges();
      updateSyncStatus("","Gesynchroniseerd");
      return;
    }
    persistPendingChanges(changes);

    // Stuur alleen de gewijzigde velden. De server verwerkt deze onder LockService,
    // zodat gelijktijdige gebruikers elkaars andere wijzigingen niet overschrijven.
    const r = await fetch(CONFIG.API_URL, {
      method:"POST",
      headers:{"Content-Type":"text/plain;charset=utf-8"},
      keepalive: keepalive === true,
      body:JSON.stringify({action:"patch", changes})
    });
    if(!r.ok) throw new Error("HTTP "+r.status);
    const response = await r.json();
    if(!response.ok) throw new Error(response.error || "Server heeft opslag geweigerd");
    const saved = sharedSnapshot(response.data || state);
    Object.assign(state, saved);
    lastSyncedShared = sharedSnapshot(saved);
    lastSyncError = null;
    clearPendingChanges();
    updateSyncStatus("","Gesynchroniseerd");
    showToast();
  }catch(err){
    failed = true;
    saveRequested = true;
    persistPendingChanges(changes);
    lastSyncError = "Opslaan mislukt: " + err.message;
    updateSyncStatus("error","Opnieuw proberen…");
    showToast(true);
  }finally{
    saveRunning = false;
    if(saveRequested){
      if(failed) scheduleSaveRetry();
      else flushSave(false);
    }
  }
}

