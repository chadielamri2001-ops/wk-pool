// 5 punten: exacte uitslag
// 3 punten: juiste verschil (bv. 2-1 voorspeld, 3-2 werkelijk)
// 1 punt: juiste uitkomst (winst/gelijk/verlies), verschil niet juist
// 0 punten: fout
function calcPoints(pred, actual){
  if(!pred || !actual) return null;
  const [ph,pa] = pred;
  const [ah,aa] = actual;
  if(ph===""||pa===""||ph===null||pa===null) return null;
  const PH=Number(ph), PA=Number(pa), AH=Number(ah), AA=Number(aa);
  if(isNaN(PH)||isNaN(PA)) return null;
  if(PH===AH && PA===AA) return 5;
  const predDiff = PH-PA;
  const actDiff = AH-AA;
  const predOutcome = Math.sign(predDiff);
  const actOutcome = Math.sign(actDiff);
  if(predOutcome!==actOutcome) return 0;
  if(predDiff===actDiff) return 3;
  return 1;
}

