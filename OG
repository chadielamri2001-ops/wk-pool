/* ---------- TIME / LOCKING ---------- */
// All match dates are "DD jun"/"DD jul" 2026, times are NL local time (Europe/Amsterdam).
const MONTH_MAP = {jun:"06", jul:"07"};
function kickoffUTCMillis(m){
  const parts = m.date.split(" "); // ["11","jun"]
  const day = parts[0].padStart(2,"0");
  const month = MONTH_MAP[parts[1]];
  // Build an ISO string and ask: what UTC instant corresponds to this wall-clock
  // time in Europe/Amsterdam? We do this by formatting a guess and adjusting
  // for the Amsterdam offset (CET=+1 / CEST=+2). June/July = CEST = +2.
  const offsetHours = 2; // CEST applies for all WK 2026 group stage dates (Jun-Jul)
  const iso = `2026-${month}-${day}T${m.time}:00`;
  const localMillis = Date.parse(iso + "Z"); // treat as if UTC, then shift
  return localMillis - offsetHours*3600*1000; // actual UTC instant
}
function isLocked(m){
  if(getActual(m)) return true;
  return Date.now() >= kickoffUTCMillis(m);
}
function isKOLocked(m){
  if(getActual(m)) return true;
  return Date.now() >= kickoffUTCMillis(m);
}

function amsterdamDatePartsFromMillis(ms){
  const parts = new Intl.DateTimeFormat('nl-NL', {
    timeZone: 'Europe/Amsterdam',
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).formatToParts(new Date(ms));
  const values = {};
  parts.forEach(p=>{ if(p.type !== 'literal') values[p.type] = p.value; });
  return values;
}
function amsterdamDateKeyFromMillis(ms){
  const parts = new Intl.DateTimeFormat('sv-SE', {
    timeZone: 'Europe/Amsterdam',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).formatToParts(new Date(ms));
  const values = {};
  parts.forEach(p=>{ if(p.type !== 'literal') values[p.type] = p.value; });
  return values.year + '-' + values.month + '-' + values.day;
}
function matchDateKey(m){ return amsterdamDateKeyFromMillis(kickoffUTCMillis(m)); }
function matchDayLabel(m){
  const p = amsterdamDatePartsFromMillis(kickoffUTCMillis(m));
  return p.weekday + ' ' + p.day + ' ' + p.month;
}
function matchTeams(m){
  if(m.home) return [m.home, m.away];
  return (state.koTeams && state.koTeams[m.id]) || String(m.placeholder || '').split(' - ');
}
function predictionLabel(pred){
  return completedPrediction(pred) ? pred[0] + '–' + pred[1] : 'Nog niet ingevuld';
}
function getLiveScore(m){
  return state.liveScores && state.liveScores[m.id] ? state.liveScores[m.id] : null;
}
function getMatchMinute(m){
  if(!state.matchMinutes || !Object.prototype.hasOwnProperty.call(state.matchMinutes,m.id)) return null;
  const minute = Number(state.matchMinutes[m.id]);
  return Number.isFinite(minute) ? minute : null;
}
function getMatchGoals(m){
  return state.matchGoals && Array.isArray(state.matchGoals[m.id]) ? state.matchGoals[m.id] : [];
}
function getApiStatus(m){
  return state.matchStatuses && state.matchStatuses[m.id] ? state.matchStatuses[m.id] : null;
}
function isLiveStatus(status){
  return ["IN_PLAY", "PAUSED", "LIVE"].includes(status);
}
function matchScheduleStatus(m){
  const status = getApiStatus(m);
  if(getActual(m)) return 'UITSLAG';
  if(status === "FINISHED") return 'AFGELOPEN';
  if(status === "PAUSED") return 'RUST';
  if(isLiveStatus(status) || getLiveScore(m)) return 'LIVE';
  if(status === "SUSPENDED") return 'ONDERBROKEN';
  if(status === "POSTPONED") return 'UITGESTELD';
  if(status === "CANCELLED") return 'AFGELAST';
  return Date.now() >= kickoffUTCMillis(m) ? 'GESLOTEN' : 'OPEN';
}
function matchStatusLabel(m){
  const status = matchScheduleStatus(m);
  const minute = getMatchMinute(m);
  if(status === 'LIVE' && minute !== null) return `LIVE ${minute}'`;
  if(status === 'RUST') return 'RUST';
  return status;
}
function matchScheduleStatusClass(m){
  const status = matchScheduleStatus(m);
  if(status === 'UITSLAG' || status === 'AFGELOPEN') return 'played';
  if(status === 'LIVE' || status === 'RUST') return 'live';
  return '';
}
function matchScoreText(m){
  const actual = getActual(m);
  if(actual) return { label: 'Uitslag', score: actual[0] + '–' + actual[1], className: 'final' };
  const live = getLiveScore(m);
  if(live) return { label: 'Live stand', score: live[0] + '–' + live[1], className: 'live' };
  return null;
}
function goalMinuteLabel(goal){
  if(!goal || goal.minute === null || goal.minute === undefined) return '';
  return goal.minute + (goal.extraTime ? '+' + goal.extraTime : '') + "'";
}
function goalTypeLabel(goal){
  if(!goal || !goal.type) return '';
  if(goal.type === 'PENALTY') return 'pen.';
  if(goal.type === 'OWN_GOAL') return 'e.d.';
  return '';
}
function goalsHtml(m){
  const goals = getMatchGoals(m);
  const live = getLiveScore(m);
  if(!goals.length){
    return live && (Number(live[0]) + Number(live[1]) > 0)
      ? '<div class="goal-list"><span class="goal-chip"><span>Doelpuntenmakers nog niet beschikbaar</span></span></div>'
      : '';
  }
  return `<div class="goal-list">${goals.map(goal=>{
    const minute = goalMinuteLabel(goal);
    const type = goalTypeLabel(goal);
    const meta = [minute, type, goal.team].filter(Boolean).join(' · ');
    return `<span class="goal-chip">${escapeHtml(goal.scorer || 'Onbekend')}${meta ? ` <span>${escapeHtml(meta)}</span>` : ''}</span>`;
  }).join('')}</div>`;
}
function liveMatchBlock(m){
  const live = getLiveScore(m);
  const status = matchScheduleStatus(m);
  if(!live && !isLiveStatus(getApiStatus(m))) return '';
  const teams = matchTeams(m);
  const minute = matchStatusLabel(m);
  return `<div class="live-panel">
    <div class="live-panel-title"><span>${escapeHtml(status === 'RUST' ? 'Ruststand' : 'Live wedstrijd')}</span><span class="live-minute">${escapeHtml(minute)}</span></div>
    <div class="live-panel-score">
      <span>${escapeHtml(teams[0] || '')}</span>
      <strong>${live ? live[0] + '–' + live[1] : '–'}</strong>
      <span style="text-align:right;">${escapeHtml(teams[1] || '')}</span>
    </div>
    ${goalsHtml(m)}
  </div>`;
}

