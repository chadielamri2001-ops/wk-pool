function renderStand(){
  const main = document.getElementById("main");
  document.getElementById("subhead").textContent = "Tussenstand poule";

  const ALL_MATCHES = MATCHES.concat(KNOCKOUT_MATCHES);
  const playedMatches = ALL_MATCHES.filter(m=>getActual(m));

  let rows = state.players.map(p=>{
    let total=0, exact=0, correctDiff=0, scoringMatches=0, played=0;
    playedMatches.forEach(m=>{
      const pred = getPred(p, m.id);
      const pts = calcPoints(pred, getActual(m));
      if(pts!==null){
        total += pts;
        played++;
        if(pts===5) exact++;
        if(pts===3) correctDiff++;
        if(pts>0) scoringMatches++;
      }
    });
    return {player:p, total, exact, correctDiff, scoringMatches, played};
  });

  rows.sort((a,b)=>
    b.total-a.total ||
    b.exact-a.exact ||
    b.correctDiff-a.correctDiff ||
    b.scoringMatches-a.scoringMatches
  );

  rows.forEach((row,i)=>{
    if(i===0){
      row.rank = 1;
      return;
    }
    const prev = rows[i-1];
    const tied = row.total===prev.total &&
      row.exact===prev.exact &&
      row.correctDiff===prev.correctDiff &&
      row.scoringMatches===prev.scoringMatches;
    row.rank = tied ? prev.rank : i+1;
  });

  const PRIZES = ["🥇 Gratis diner (de rest trakteert)","🥈 Gratis drinken bij het eten","🥉 Mag de eetplek uitkiezen"];

  let html = `<div class="rules-box">
