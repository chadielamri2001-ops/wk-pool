    html+=`<div class="rules-box schedule-note"><b>${scheduleLabel}</b><br>Nederlandse tijd. Nachtwedstrijden staan op hun startdatum.</div>`;
    html+=`<div class="group-card schedule-list">`;
    schedule.forEach(m=>{
      const pred=getPred(state.current,m.id);
      const teams=matchTeams(m);
      const status=matchScheduleStatus(m);
      const statusClass=matchScheduleStatusClass(m);
      const predText=predictionLabel(pred);
      const score = matchScoreText(m);
      const scoreHtml = score ? `<span>${score.label}</span><b class="schedule-score ${score.className}">${score.score}</b>` : `<span>Jouw voorspelling</span><b>${predText}</b>`;
      html+=`<div class="match schedule-match ${statusClass==='played'?'played':''}"><div class="schedule-top"><span><span class="schedule-time">${m.time}</span> <span class="schedule-id">${m.id}</span></span><span class="match-status ${statusClass}">${escapeHtml(matchStatusLabel(m))}</span></div><div class="teams-row"><div class="team-name">${escapeHtml(teams[0]||'')}</div><div class="score-inputs"><input type="number" min="0" max="20" inputmode="numeric" data-match="${m.id}" data-idx="0" value="${pred[0]??''}" ${isLocked(m)?'disabled':''}><span class="dash">–</span><input type="number" min="0" max="20" inputmode="numeric" data-match="${m.id}" data-idx="1" value="${pred[1]??''}" ${isLocked(m)?'disabled':''}></div><div class="team-name right">${escapeHtml(teams[1]||'')}</div></div>${statusClass==='live' ? goalsHtml(m) : ''}<div class="schedule-pick">${scoreHtml}</div>${score ? `<div class="schedule-pick"><span>Jouw voorspelling</span><b>${predText}</b></div>` : ''}${isLocked(m) ? otherPredictionsHtml(m) : ''}</div>`;
    });
    html+=`</div>`;
  }

  main.innerHTML=html;bindCommonHandlers();
  const gg=document.getElementById('goGroups');if(gg)gg.onclick=()=>{state.view='groep';render()};
  bindPredictionHandlers(main,false);
}
function bindPredictionHandlers(root,rerender=true){
  root.querySelectorAll('input[data-match]').forEach(inp=>{
    inp.addEventListener('input',()=>{
      const val=inp.value===''?null:inp.value;
      setPred(state.current,inp.dataset.match,Number(inp.dataset.idx),val);
    });
    inp.addEventListener('keydown',(ev)=>{
      if(ev.key==="Enter"){
        ev.preventDefault();
        commitDraftPrediction(state.current,inp.dataset.match,true);
        inp.blur();
      }
    });
    inp.addEventListener('focusout',()=>{
      const player = state.current;
      const matchId = inp.dataset.match;
      setTimeout(()=>{
        const active = document.activeElement;
        const stillEditingSameMatch = active && active.dataset && active.dataset.match === matchId;
        if(!stillEditingSameMatch) commitDraftPrediction(player,matchId,true);
      },0);
    });
  });
}

