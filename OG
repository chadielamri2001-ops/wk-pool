function bindCommonHandlers(){
  const sw = document.getElementById("switchUserBtn");
  if(sw) sw.onclick = ()=>{ renderLogin(); };
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}
function escapeAttr(s){ return escapeHtml(s); }

/* ---------- LOGIN ---------- */
function renderLogin(){
  const main = document.getElementById("main");
  document.getElementById("tabs").style.display = "none";
  document.getElementById("subhead").textContent = "Wie ben jij?";

  let html = `<div class="rules-box">Kies je naam. Dit onthouden we op dit toestel.</div>`;
  html += `<div class="player-select">${state.players.map(p=>
    `<button class="player-chip" data-login="${escapeAttr(p)}">${escapeHtml(p)}</button>`
  ).join("")}</div>`;

  main.innerHTML = html;

  main.querySelectorAll('[data-login]').forEach(btn=>{
    btn.onclick = ()=>{
      const name = btn.dataset.login;
      const adminSession = isAdmin();
      state.current = name;
      if(!adminSession) saveLocalName(name);
      document.getElementById("tabs").style.display = "";
      render();
    };
  });
}

window.addEventListener("online", ()=>{ updateSyncStatus("","Online"); if(saveRequested) flushSave(); });
window.addEventListener("offline", ()=>updateSyncStatus("error","Offline"));
window.addEventListener("pagehide", ()=>{
  commitAllCompleteDrafts(true);
  if(saveRequested && !saveRunning) flushSave(true);
});

/* ---------- INIT ---------- */
(async function(){
  await loadState();
  const pendingChanges = readPendingChanges();
  if(pendingChanges.length){
    applyChanges(state, pendingChanges);
    saveRequested = true;
    updateSyncStatus("error","Opnieuw proberen…");
    scheduleSaveRetry(800);
  }
  const localName = await loadLocalName();
  if(localName && state.players.includes(localName)){
    state.localName = localName;
    state.current = localName;
    render();
  } else {
    renderLogin();
  }

  // Haal wijzigingen van andere spelers regelmatig op, maar nooit tijdens een lokale opslagactie.
  if(CONFIG.API_URL && CONFIG.API_URL.indexOf("http")===0){
    setInterval(async ()=>{
      if(saveRunning || saveRequested || hasLocalDrafts()) return;
      const before = JSON.stringify(sharedSnapshot());
      await loadState();
      const after = JSON.stringify(sharedSnapshot());
      if(before!==after) render();
    }, 12000);
    window.addEventListener("focus", async ()=>{
      if(saveRunning || saveRequested || hasLocalDrafts()) return;
      const before = JSON.stringify(sharedSnapshot());
      await loadState();
      if(before!==JSON.stringify(sharedSnapshot())) render();
    });
  }
})();
</script>
