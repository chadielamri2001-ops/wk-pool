          <input type="number" min="0" max="20" inputmode="numeric" data-match="${m.id}" data-idx="1" value="${pred[1]??''}" ${locked?'disabled':''}>
        </div>
        <div class="team-name right" style="font-size:${hasTeams?'0.95rem':'0.75rem'};color:${hasTeams?'var(--text)':'var(--muted)'};">${escapeHtml(awayLabel)}</div>
      </div>${otherPredictionsHtml(m)}
      <div class="actual-row" style="justify-content:space-between;">
        <span class="lbl edit-actual-link" data-editteams="${m.id}" style="text-decoration:underline;cursor:pointer;">wijzig teams</span>
      </div>`;

    if(state.editingTeams===m.id){
      html += `<div class="actual-row" style="margin-top:4px;gap:6px;">
        <input type="text" data-teamname="${m.id}" data-idx="0" placeholder="Team 1" value="${hasTeams?escapeAttr(teams[0]):''}" style="flex:1;padding:6px 8px;border-radius:8px;border:1px solid var(--line);background:var(--bg);color:var(--text);font-size:0.8rem;">
        <input type="text" data-teamname="${m.id}" data-idx="1" placeholder="Team 2" value="${hasTeams?escapeAttr(teams[1]):''}" style="flex:1;padding:6px 8px;border-radius:8px;border:1px solid var(--line);background:var(--bg);color:var(--text);font-size:0.8rem;">
        <button class="save-actual-btn" data-saveteams="${m.id}" style="padding:6px 12px;border-radius:8px;border:none;background:var(--accent);color:#1a1300;font-weight:700;font-size:0.75rem;">Opslaan</button>
      </div>`;
    }

    if(!played && !locked){
      // teams known, not yet played -> nothing extra
    }

    if(hasTeams && !played && isKOLocked(m)){
      html += `<div class="actual-row" style="margin-top:4px;">
        <span class="lbl">Uitslag invullen:</span>
        <input type="number" min="0" max="20" inputmode="numeric" data-actual="${m.id}" data-idx="0" value="">
        <span class="dash">–</span>
        <input type="number" min="0" max="20" inputmode="numeric" data-actual="${m.id}" data-idx="1" value="">
        <button class="save-actual-btn" data-saveactual="${m.id}" style="padding:6px 12px;border-radius:8px;border:none;background:var(--accent);color:#1a1300;font-weight:700;font-size:0.75rem;">Opslaan</button>
      </div>`;
    }

    if(played){
      html += `<div class="actual-row">
        <span class="lbl">Uitslag</span>
        <span style="font-weight:800;color:var(--accent2);font-size:1rem;">${actual[0]} – ${actual[1]}</span>
        <span class="edit-actual-link" data-editactual="${m.id}" style="color:var(--muted);font-size:0.7rem;text-decoration:underline;margin-left:6px;">wijzig</span>
      </div>`;
      if(points!==null){
        html += `<div class="points-pill ${points===0?'zero':''}">${points} punten</div>`;
      } else {
        html += `<div class="points-pill zero">geen voorspelling</div>`;
      }
      if(state.editingActual===m.id){
        html += `<div class="actual-row" style="margin-top:4px;">
          <span class="lbl">Nieuwe uitslag:</span>
          <input type="number" min="0" max="20" inputmode="numeric" data-actual="${m.id}" data-idx="0" value="${actual[0]}">
          <span class="dash">–</span>
          <input type="number" min="0" max="20" inputmode="numeric" data-actual="${m.id}" data-idx="1" value="${actual[1]}">
          <button class="save-actual-btn" data-saveactual="${m.id}" style="padding:6px 12px;border-radius:8px;border:none;background:var(--accent);color:#1a1300;font-weight:700;font-size:0.75rem;">Opslaan</button>
        </div>`;
      }
    }

    html += `</div>`;
  });
  html += `</div>`;

  main.innerHTML = html;
  bindCommonHandlers();
  bindKnockoutHandlers(main);
}

function bindKnockoutHandlers(main){
  bindPredictionHandlers(main,false);

  main.querySelectorAll('[data-editteams]').forEach(el=>{
    el.onclick = ()=>{
      state.editingTeams = (state.editingTeams===el.dataset.editteams) ? null : el.dataset.editteams;
      render();
    };
  });

  main.querySelectorAll('[data-saveteams]').forEach(btn=>{
    btn.onclick = ()=>{
      const mid = btn.dataset.saveteams;
      const inputs = main.querySelectorAll(`input[data-teamname="${mid}"]`);
      const t1 = inputs[0].value.trim(), t2 = inputs[1].value.trim();
      if(!t1 || !t2) return;
      if(!state.koTeams) state.koTeams = {};
      state.koTeams[mid] = [t1, t2];
      state.editingTeams = null;
      saveState();
      render();
    };
  });

  main.querySelectorAll('[data-saveactual]').forEach(btn=>{
    btn.onclick = ()=>{
      const mid = btn.dataset.saveactual;
      const inputs = main.querySelectorAll(`input[data-actual="${mid}"]`);
      const h = inputs[0].value, a = inputs[1].value;
      if(h==="" || a===""){ return; }
      if(!state.actuals) state.actuals = {};
      state.actuals[mid] = [Number(h), Number(a)];
      state.editingActual = null;
      saveState();
      render();
    };
  });

  main.querySelectorAll('[data-editactual]').forEach(el=>{
    el.onclick = ()=>{
      state.editingActual = (state.editingActual===el.dataset.editactual) ? null : el.dataset.editactual;
      render();
    };
  });
}


