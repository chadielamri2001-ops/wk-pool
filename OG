  const available=all.filter(m=>!isLocked(m));
  const filled=available.filter(m=>completedPrediction(getPred(state.current,m.id))).length;
  const pct=available.length?Math.round(filled/available.length*100):100;
  const played=all.filter(m=>getActual(m));
