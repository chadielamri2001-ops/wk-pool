function draftKey(player, matchId){ return player + "||" + matchId; }

function getPred(player, matchId){
  const key = draftKey(player, matchId);
  if(Object.prototype.hasOwnProperty.call(draftPredictions, key)) return draftPredictions[key];
  const p = state.predictions[player];
  if(!p) return [null,null];
  return p[matchId] || [null,null];
}

function setPred(player, matchId, idx, val){
  const key = draftKey(player, matchId);
  const current = getPred(player, matchId).slice();
  current[idx] = val;
  draftPredictions[key] = current;
  if(!draftTouches[key]) draftTouches[key] = {};
  draftTouches[key][idx] = true;

  const status = draftPredictionStatus(current);
  updateSyncStatus(status.type, status.text);
  scheduleDraftCommit(player, matchId);
}

function draftPredictionStatus(pred){
  const home = pred ? pred[0] : null;
  const away = pred ? pred[1] : null;
  const homeEmpty = home === null || home === "";
  const awayEmpty = away === null || away === "";
  if(homeEmpty && awayEmpty) return {type:"saving", text:"Lokaal verwijderen"};
  if(homeEmpty || awayEmpty) return {type:"saving", text:"Nog één score invullen"};

  const h = Number(home), a = Number(away);
  if(!Number.isInteger(h) || !Number.isInteger(a) || h < 0 || a < 0 || h > 30 || a > 30){
    return {type:"error", text:"Controleer score"};
  }
  return {type:"saving", text:"Lokaal concept"};
}

function clearDraftCommitTimer(key){
  if(draftSaveTimers[key]) clearTimeout(draftSaveTimers[key]);
  delete draftSaveTimers[key];
}

function canAutoCommitDraft(key, pred){
  const status = draftPredictionStatus(pred);
  const touched = draftTouches[key] || {};
  return touched[0] && touched[1] && (status.text === "Lokaal concept" || status.text === "Lokaal verwijderen");
}

function scheduleDraftCommit(player, matchId){
  const key = draftKey(player, matchId);
  clearDraftCommitTimer(key);
  if(!canAutoCommitDraft(key, draftPredictions[key])) return;

  draftSaveTimers[key] = setTimeout(()=>{
    delete draftSaveTimers[key];
    commitDraftPrediction(player, matchId, false);
  }, 900);
}

function commitDraftPrediction(player, matchId, immediate=true){
  const key = draftKey(player, matchId);
  if(!Object.prototype.hasOwnProperty.call(draftPredictions, key)) return false;
  clearDraftCommitTimer(key);

  const current = draftPredictions[key].slice();

  const [home, away] = current;
  const homeEmpty = home === null || home === "";
  const awayEmpty = away === null || away === "";
  const bothEmpty = homeEmpty && awayEmpty;
  const bothFilled = !homeEmpty && !awayEmpty && Number.isInteger(Number(home)) && Number.isInteger(Number(away));

  if(bothFilled){
    const h = Number(home), a = Number(away);
    if(h < 0 || a < 0 || h > 30 || a > 30){
      draftPredictions[key] = current;
      updateSyncStatus("error","Controleer score");
      return false;
    }
    if(!state.predictions[player]) state.predictions[player]={};
    state.predictions[player][matchId] = [h, a];
    delete draftPredictions[key];
    delete draftTouches[key];
    saveState(immediate);
    return true;
  } else if(bothEmpty){
    const hadPrediction = state.predictions[player] && Object.prototype.hasOwnProperty.call(state.predictions[player], matchId);
    if(state.predictions[player] && Object.prototype.hasOwnProperty.call(state.predictions[player], matchId)){
      delete state.predictions[player][matchId];
    }
    delete draftPredictions[key];
    delete draftTouches[key];
    if(hadPrediction) saveState(immediate);
    return hadPrediction;
  } else {
    draftPredictions[key] = current;
    updateSyncStatus("saving","Nog één score invullen");
    return false;
  }
}

function commitAllCompleteDrafts(immediate=true){
  let changed = false;
  Object.keys(draftPredictions).forEach(key=>{
    const splitAt = key.indexOf("||");
    if(splitAt < 0) return;
    const player = key.slice(0, splitAt);
    const matchId = key.slice(splitAt + 2);
    const pred = draftPredictions[key];
    const status = draftPredictionStatus(pred);
    if(status.text === "Lokaal concept" || status.text === "Lokaal verwijderen"){
      if(commitDraftPrediction(player, matchId, immediate)) changed = true;
    }
  });
  return changed;
}

function finalPoints(player, match, raw){ return raw; }
function completedPrediction(pred){ return pred && pred[0]!==null && pred[0]!=='' && pred[1]!==null && pred[1]!==''; }
function otherPredictionsHtml(match){
  if(!isLocked(match)) return '';
  const picks=state.players.map(p=>({p,pred:getPred(p,match.id)})).filter(x=>completedPrediction(x.pred));
  if(!picks.length) return '';
  return `<div class="other-picks">${picks.map(x=>`<span class="pick-chip"><b>${escapeHtml(x.p)}</b> ${x.pred[0]}–${x.pred[1]}</span>`).join('')}</div>`;
}

