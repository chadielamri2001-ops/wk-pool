function renderSpelers(){
  const main = document.getElementById("main");
  document.getElementById("subhead").textContent = "Spelers beheren";

  let html = `<div class="manage-row">
    <input type="text" id="newPlayerName" placeholder="Naam van vriend(in)">
    <button id="addPlayerBtn">Toevoegen</button>
  </div>`;

  state.players.forEach(p=>{
    html += `<div class="player-row">
      <input type="text" class="rename-input" data-rename="${escapeAttr(p)}" value="${escapeAttr(p)}" style="flex:1;margin-right:8px;padding:7px 10px;border-radius:8px;border:1px solid var(--line);background:var(--bg);color:var(--text);font-size:0.9rem;">
      ${state.players.length>1?`<span class="remove" data-remove="${escapeAttr(p)}">Verwijderen</span>`:''}
    </div>`;
  });

  html += `<div class="rules-box" style="margin-top:14px;">
    Alleen admin. Namen aanpassen werkt direct door in de stand en voorspellingen.
  </div>`;

  main.innerHTML = html;

  document.getElementById("addPlayerBtn").onclick = ()=>{
    const input = document.getElementById("newPlayerName");
    const name = input.value.trim();
    if(name && !state.players.includes(name)){
      state.players.push(name);
      saveState();
      render();
    }
  };

  main.querySelectorAll('.rename-input').forEach(inp=>{
    inp.addEventListener("change", ()=>{
      const oldName = inp.dataset.rename;
      const newName = inp.value.trim();
      if(!newName || newName===oldName) { inp.value = oldName; return; }
      if(state.players.includes(newName)){ inp.value = oldName; return; }
      // rename in players list
      state.players = state.players.map(p=>p===oldName?newName:p);
      // move predictions
      if(state.predictions[oldName]){
        state.predictions[newName] = state.predictions[oldName];
        delete state.predictions[oldName];
      }
      if(state.current===oldName) state.current = newName;
      if(state.localName===oldName) state.localName = newName;
      saveLocalName(newName);
      saveState();
      render();
    });
  });

  main.querySelectorAll('[data-remove]').forEach(el=>{
    el.onclick = ()=>{
      const name = el.dataset.remove;
      state.players = state.players.filter(p=>p!==name);
      delete state.predictions[name];
      if(state.current===name) state.current = state.players[0];
      saveState();
      render();
    };
  });
}

