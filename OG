function updateSyncStatus(mode, text){
  const box = document.getElementById("syncStatus");
  const label = document.getElementById("syncText");
  if(!box || !label) return;
  box.className = "sync-status" + (mode ? " "+mode : "");
  label.textContent = text || (mode==="saving" ? "Opslaan…" : mode==="error" ? "Offline" : "Gesynchroniseerd");
}
function collectChanges(base, local, path=[], out=[]){
  if(JSON.stringify(base)===JSON.stringify(local)) return out;
  const baseObj = base && typeof base==="object";
  const localObj = local && typeof local==="object";
  if(!baseObj || !localObj || Array.isArray(base) || Array.isArray(local)){
    out.push({path, value:local, deleted:local===undefined});
    return out;
  }
  const keys = new Set([...Object.keys(base||{}), ...Object.keys(local||{})]);
  keys.forEach(k=>collectChanges(base?.[k], local?.[k], path.concat(k), out));
  return out;
}
function applyChanges(target, changes){
  changes.forEach(ch=>{
    let obj=target;
    for(let i=0;i<ch.path.length-1;i++){
      const k=ch.path[i];
      if(!obj[k] || typeof obj[k]!=="object") obj[k]={};
      obj=obj[k];
    }
    const key=ch.path[ch.path.length-1];
    if(ch.path.length===0) return;
    if(ch.deleted) delete obj[key];
    else obj[key]=JSON.parse(JSON.stringify(ch.value));
  });
  return target;
}
function hasLocalDrafts(){
  return typeof draftPredictions !== "undefined" && Object.keys(draftPredictions).length > 0;
