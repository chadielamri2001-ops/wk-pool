<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#e9eee9">
<title>WK 2026 Voorspelpoule</title>
<style>
  :root{
    color-scheme:light;
    --bg:#e9eee9;
    --bg-soft:#dde6e0;
    --panel:#f8faf7;
    --panel-solid:#f8faf7;
    --panel2:#eef4ef;
    --line:#cad6d0;
    --line-strong:#aebdb5;
    --accent:#1457c8;
    --accent-strong:#0f4fb7;
    --accent2:#07865d;
    --accent-red:#c9272d;
    --gold:#b88a2e;
    --text:#111827;
    --muted:#66736d;
    --red:#c9272d;
    --warning:#b7791f;
    --shadow:0 18px 45px rgba(10,31,44,.12);
    --shadow-soft:0 8px 22px rgba(10,31,44,.08);
    --radius:8px;
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html{scroll-behavior:smooth;background:var(--bg);}
  body{
    margin:0;
    min-height:100vh;
    font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:
      linear-gradient(145deg,rgba(20,87,200,.08),transparent 28%),
      linear-gradient(215deg,rgba(7,134,93,.10),transparent 34%),
      linear-gradient(180deg,#e4ebe5 0%,#d8e4dd 45%,#eef2ec 100%);
    color:var(--text);
    padding-bottom:76px;
    font-size:15px;
  }
  button,input{font:inherit;}
  button{cursor:pointer;}
  header{
    padding:18px 16px 14px;
    text-align:left;
    border-bottom:1px solid var(--line);
    position:sticky;
    top:0;
    background:rgba(242,246,241,.90);
    backdrop-filter:blur(18px) saturate(135%);
    -webkit-backdrop-filter:blur(18px) saturate(135%);
    z-index:20;
  }
  header::before{content:"";position:absolute;left:0;right:0;top:0;height:3px;background:linear-gradient(90deg,var(--accent-red),var(--accent2),var(--accent));}
  .header-inner{max-width:1040px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px;}
  .brand{min-width:0;}
  header h1{margin:0;font-size:clamp(1.1rem,3vw,1.42rem);letter-spacing:0;font-weight:720;line-height:1.1;}
  header h1 span{color:var(--accent-strong);font-weight:780;}
  header p{margin:5px 0 0;color:var(--muted);font-size:.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .sync-status{display:flex;align-items:center;gap:7px;flex:0 0 auto;padding:7px 10px;border:1px solid var(--line);background:var(--panel);border-radius:999px;color:var(--muted);font-size:.72rem;font-weight:620;box-shadow:var(--shadow-soft);}
  .sync-dot{width:8px;height:8px;border-radius:50%;background:var(--accent2);box-shadow:0 0 0 3px rgba(7,134,93,.12);}
  .sync-status.saving .sync-dot{background:var(--warning);box-shadow:0 0 0 3px rgba(183,121,31,.14);animation:pulse 1s infinite;}
  .sync-status.error .sync-dot{background:var(--red);box-shadow:0 0 0 3px rgba(201,39,45,.12);}
  @keyframes pulse{50%{opacity:.4;}}

  .tabs{
    display:flex;gap:6px;padding:10px 14px;overflow-x:auto;border-bottom:1px solid var(--line);
    position:sticky;top:73px;background:rgba(232,239,233,.92);backdrop-filter:blur(16px);z-index:15;
    -webkit-overflow-scrolling:touch;scrollbar-width:none;
  }
  .tabs::-webkit-scrollbar{display:none;}
  .tab{flex:0 0 auto;padding:9px 13px;border-radius:999px;background:transparent;color:var(--muted);border:1px solid transparent;font-size:.82rem;font-weight:620;white-space:nowrap;transition:.18s ease;}
  .tab:hover{color:var(--text);background:rgba(17,24,39,.04);}
  .tab.active{background:var(--panel);color:var(--accent-strong);border-color:#b7c8ed;box-shadow:var(--shadow-soft);}

  main{padding:18px 14px;max-width:920px;margin:0 auto;}
  .player-select{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
  .player-chip{min-height:40px;padding:8px 13px;border-radius:999px;background:var(--panel);border:1px solid var(--line);color:var(--text);font-size:.84rem;font-weight:620;box-shadow:var(--shadow-soft);transition:.18s ease;}
  .player-chip:hover{transform:translateY(-1px);border-color:var(--line-strong);}
  .player-chip.active{background:#dcefe7;color:#065f46;border-color:#92cdb8;}

  .group-card,.rules-box,.lb-table,.player-row{
    background:var(--panel);
    border:1px solid var(--line);box-shadow:var(--shadow-soft);
  }
  .group-card{border-radius:var(--radius);margin-bottom:18px;overflow:hidden;}
  .group-head{padding:14px 16px;font-weight:680;font-size:.94rem;background:var(--panel2);border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;gap:12px;}
  .group-head .teams{color:var(--muted);font-weight:450;font-size:.72rem;text-align:right;line-height:1.35;}
  .match{padding:15px 16px;border-bottom:1px solid var(--line);display:flex;flex-direction:column;gap:11px;transition:.18s ease;}
  .match:last-child{border-bottom:none;}
  .match.played{background:linear-gradient(90deg,rgba(7,134,93,.06),transparent 58%);}
  .match-top{display:flex;justify-content:space-between;align-items:center;font-size:.72rem;color:var(--muted);}
  .match-status{font-size:.62rem;font-weight:700;letter-spacing:.04em;padding:4px 8px;border-radius:999px;background:#e7eee9;border:1px solid var(--line);color:var(--muted);}
  .match-status.played{background:#dcefe7;color:#047857;border-color:#92cdb8;}
  .match-status.live{background:#f4e7c9;color:#7a4b0e;border-color:#d2aa5c;}
  .teams-row{display:grid;grid-template-columns:minmax(0,1fr) auto minmax(0,1fr);align-items:center;gap:10px;}
  .team-name{font-weight:630;font-size:.94rem;line-height:1.25;overflow-wrap:anywhere;}
  .team-name.right{text-align:right;}
  .score-inputs{display:flex;align-items:center;gap:7px;justify-content:center;}
  .score-inputs input,.actual-row input[type="number"]{width:46px;height:46px;text-align:center;font-size:1.04rem;font-weight:650;border-radius:8px;border:1px solid var(--line-strong);background:#f1f5f1;color:var(--text);box-shadow:inset 0 1px 2px rgba(15,23,42,.06);}
  .score-inputs input:focus,.actual-row input:focus,.manage-row input:focus,.rename-input:focus{outline:none;border-color:#83a6e6;box-shadow:0 0 0 3px rgba(20,87,200,.12);}
  input:disabled{opacity:.48;cursor:not-allowed;}
  .score-inputs .dash{color:var(--muted);font-weight:620;}
  .actual-row{display:flex;justify-content:center;align-items:center;gap:8px;font-size:.8rem;color:var(--muted);flex-wrap:wrap;}
  .actual-row .lbl{font-size:.67rem;text-transform:uppercase;letter-spacing:.055em;font-weight:650;}
  .points-pill{align-self:center;font-size:.69rem;font-weight:720;padding:5px 10px;border-radius:999px;background:#dde8fb;border:1px solid #aebfe6;color:var(--accent-strong);}
  .points-pill.zero{background:#e7eee9;border-color:var(--line);color:var(--muted);}

  .lb-table{width:100%;border-collapse:separate;border-spacing:0;border-radius:var(--radius);overflow:hidden;}
  .lb-table th,.lb-table td{padding:13px 13px;text-align:left;font-size:.88rem;}
  .lb-table th{background:var(--panel2);color:var(--muted);font-size:.66rem;text-transform:uppercase;letter-spacing:.065em;font-weight:650;}
  .lb-table tr:not(:last-child) td{border-bottom:1px solid var(--line);}
  .lb-table td.points{font-weight:720;color:var(--accent-strong);text-align:right;}
  .lb-table td.rank{color:var(--muted);font-weight:700;width:34px;}
  .lb-table tr.you td{background:#dde8fb;}
  .rules-box{border-radius:var(--radius);padding:14px 15px;margin-bottom:15px;font-size:.84rem;line-height:1.5;color:var(--muted);}
  .rules-box b{color:var(--text);}
  .rules-box ul{margin:7px 0 0;padding-left:20px;}
  .legend{display:flex;gap:14px;flex-wrap:wrap;font-size:.73rem;color:var(--muted);margin-bottom:12px;}
  .legend span{display:flex;align-items:center;gap:6px;}
  .dot{width:9px;height:9px;border-radius:50%;display:inline-block;}.dot.green{background:var(--accent2);}.dot.gold{background:var(--gold);}
  .empty{text-align:center;color:var(--muted);padding:36px 12px;font-size:.9rem;}
  .save-toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(20px);background:#0f513f;color:#fff;padding:10px 16px;border-radius:999px;font-weight:650;font-size:.78rem;opacity:0;transition:.22s ease;pointer-events:none;z-index:50;box-shadow:0 15px 36px rgba(15,23,42,.22);}
  .save-toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
  .manage-row{display:flex;gap:9px;margin-bottom:15px;}
  .manage-row input,.rename-input{flex:1;min-width:0;padding:12px 13px;border-radius:8px;border:1px solid var(--line);background:#f1f5f1;color:var(--text);font-size:.9rem;}
  .manage-row button,.save-actual-btn{min-height:42px;padding:9px 14px;border-radius:8px;border:1px solid #0f4fb7!important;background:var(--accent-strong)!important;color:#fff!important;font-weight:650!important;box-shadow:0 8px 18px rgba(20,87,200,.18);}
  .player-row{display:flex;justify-content:space-between;align-items:center;border-radius:8px;padding:10px 12px;margin-bottom:9px;}
  .player-row .remove{color:var(--red);font-weight:650;font-size:.78rem;padding:8px;cursor:pointer;}
  code{background:#eef2ee;padding:2px 5px;border-radius:6px;}


  .dashboard-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px;}
  .stat-card{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:14px 15px;box-shadow:var(--shadow-soft);}
  .stat-value{font-size:1.36rem;font-weight:760;letter-spacing:0;color:var(--text);}
  .stat-label{margin-top:4px;color:var(--muted);font-size:.72rem;font-weight:580;}
  .progress-track{height:9px;border-radius:999px;background:rgba(148,163,184,.12);overflow:hidden;margin:12px 0 4px;}
  .progress-fill{height:100%;border-radius:inherit;background:linear-gradient(90deg,var(--accent-red),var(--accent2),var(--accent));}
  .section-title{display:flex;align-items:center;justify-content:space-between;gap:10px;margin:18px 2px 10px;font-size:.92rem;font-weight:700;}
  .match-actions{display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;}
  .other-picks{margin-top:4px;padding-top:9px;border-top:1px dashed var(--line);display:flex;gap:6px;flex-wrap:wrap;}
  .pick-chip{padding:5px 8px;border-radius:999px;background:#eef4ef;border:1px solid var(--line);font-size:.68rem;color:var(--muted);}
  .pick-chip b{color:var(--text);}
  .mini-btn{flex:0 0 auto;min-height:36px;padding:8px 12px;border-radius:999px;border:1px solid var(--line);background:var(--panel);color:var(--muted);font-size:.76rem;font-weight:620;box-shadow:var(--shadow-soft);}
  .schedule-note{padding:12px 14px;margin-bottom:10px;}
  .schedule-list{overflow:hidden;}
  .schedule-match{gap:9px;}
  .schedule-top{display:flex;align-items:center;justify-content:space-between;gap:8px;font-size:.72rem;color:var(--muted);}
  .schedule-time{font-weight:700;color:var(--text);font-size:.9rem;}
  .schedule-id{font-weight:620;color:var(--muted);}
  .schedule-pick{display:flex;align-items:center;justify-content:space-between;gap:8px;color:var(--muted);font-size:.72rem;font-weight:620;}
  .schedule-pick b{color:var(--text);font-size:.88rem;}
  .schedule-score.live{color:#8a5a12;}
  .schedule-score.final{color:#047857;}
  .live-panel{margin:0 0 14px;padding:14px 15px;border-radius:8px;background:linear-gradient(90deg,#f4e7c9,#eef4ef);border:1px solid #d2aa5c;box-shadow:var(--shadow-soft);}
  .live-panel-title{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-bottom:10px;font-size:.78rem;color:#8a5a12;font-weight:680;letter-spacing:0;}
  .live-panel-score{display:grid;grid-template-columns:minmax(0,1fr) auto minmax(0,1fr);gap:10px;align-items:center;font-size:1rem;}
  .live-panel-score span{min-width:0;overflow-wrap:anywhere;}
  .live-panel-score strong{font-size:1.45rem;font-weight:760;color:var(--text);white-space:nowrap;}
  .live-minute{display:inline-flex;align-items:center;gap:5px;padding:4px 8px;border-radius:999px;background:#fff9ec;border:1px solid #d2aa5c;color:#7a4b0e;font-weight:700;}
  .goal-list{margin-top:10px;display:flex;gap:6px;flex-wrap:wrap;}
  .goal-chip{font-size:.72rem;color:var(--text);background:#f8faf7;border:1px solid var(--line);border-radius:999px;padding:5px 8px;}
  .goal-chip span{color:var(--muted);}

  @media(max-width:700px){
    body{padding-bottom:92px;}
    header{padding:15px 13px 13px;}
    .sync-status{padding:7px 9px;}.sync-status span:last-child{display:none;}
    .tabs{position:fixed;left:0;right:0;bottom:0;top:auto;z-index:40;border-top:1px solid var(--line);border-bottom:0;padding:8px 8px calc(8px + env(safe-area-inset-bottom));justify-content:space-around;background:rgba(242,246,241,.96);box-shadow:0 -12px 30px rgba(15,23,42,.13);}
    .tab{flex:1;min-width:0;padding:7px 3px;border-radius:8px;font-size:.64rem;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;min-height:48px;}
    .tab .tab-icon{display:none;}.tab .tab-label{display:block;max-width:100%;overflow:hidden;text-overflow:ellipsis;}.tab.active{background:#dde8fb;}
    .dashboard-grid{grid-template-columns:repeat(3,1fr);gap:8px}.stat-card{padding:12px 10px}.stat-value{font-size:1.16rem}.stat-label{font-size:.62rem}
    main{padding:14px 10px;}
    .group-head{align-items:flex-start;}.group-head .teams{max-width:68%;}
    .match{padding:14px 12px;}
    .team-name{font-size:.86rem;}
    .score-inputs input,.actual-row input[type="number"]{width:44px;height:44px;}
    .schedule-note{padding:10px 12px;font-size:.78rem;line-height:1.45;}
    .schedule-match{padding:11px 10px;gap:8px;}
    .schedule-top{font-size:.68rem;}
    .schedule-time{font-size:.86rem;}
    .schedule-match .teams-row{grid-template-columns:minmax(0,1fr) auto minmax(0,1fr);gap:6px;}
    .schedule-match .team-name{font-size:.78rem;line-height:1.18;}
    .schedule-match .score-inputs{gap:4px;}
    .schedule-match .score-inputs input{width:38px;height:40px;border-radius:11px;font-size:.95rem;}
    .schedule-pick{font-size:.66rem;padding-top:2px;}
    .schedule-pick b{font-size:.8rem;}
    .live-panel{padding:12px;}
    .live-panel-score{font-size:.86rem;gap:6px;}
    .live-panel-score strong{font-size:1.24rem;}
    .goal-chip{font-size:.68rem;}
    .manage-row{flex-direction:column;}.manage-row button{width:100%;}
    .lb-table{display:block;overflow-x:auto;white-space:nowrap;}
    .rules-box{padding:13px;}
  }
  @media(max-width:390px){
    .teams-row{gap:6px;}.team-name{font-size:.79rem;}.score-inputs{gap:4px;}.score-inputs input{width:40px;height:42px;}
  }
</style>
</head>
