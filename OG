  let html=renderCurrentUserBar();
  html+=`<div class="dashboard-grid"><div class="stat-card"><div class="stat-value">${total}</div><div class="stat-label">Punten</div></div><div class="stat-card"><div class="stat-value">#${rank}</div><div class="stat-label">Positie</div></div><div class="stat-card"><div class="stat-value">${filled}/${available.length}</div><div class="stat-label">Open ingevuld</div></div></div>`;
